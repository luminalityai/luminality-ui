// For format details, see https://containers.dev/implementors/json_reference/.
{
  "name": "luminality-ui",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
  },
  "postCreateCommand": "npm ci && (npm install -g @anthropic-ai/claude-code || echo 'Note: Claude Code installation failed. Install manually with: npm install -g @anthropic-ai/claude-code')"
}
